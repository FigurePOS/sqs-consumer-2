{
    "name": "@figurepos/sqs-consumer",
    "version": "5.8.0",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "scripts": {
        "build": "yarn run clean && tsc",
        "clean": "rm -fr lib/*",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --fix",
        "posttest": "yarn run lint",
        "prepublish": "yarn run build",
        "pretest": "yarn run build",
        "prettier": "./node_modules/.bin/prettier --write '**/*.js' '**/*.json' '**/*.ts'",
        "test": "export TZ='America/New_York'; jest",
        "test:ci": "yarn run test --runInBand",
        "typecheck": "tsc --noEmit",
        "watch": "tsc --watch"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/FigurePOS/sqs-consumer-2.git"
    },
    "bugs": {
        "url": "https://github.com/FigurePOS/sqs-consumer-2/issues"
    },
    "homepage": "https://github.com/FigurePOS/sqs-consumer-2",
    "keywords": [
        "sqs",
        "queue",
        "consumer"
    ],
    "license": "Apache-2.0",
    "devDependencies": {
        "@aws-sdk/client-sqs": "3.391.0",
        "@release-it/conventional-changelog": "^8.0.1",
        "@types/debug": "^4.1.12",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.11.30",
        "@types/sinon": "^9.0.4",
        "@typescript-eslint/eslint-plugin": "^7.3.1",
        "@typescript-eslint/parser": "^7.3.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^29.5.0",
        "p-event": "^6.0.1",
        "prettier": "^3.2.5",
        "release-it": "^17.1.1",
        "sinon": "^17.0.1",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.3"
    },
    "dependencies": {
        "debug": "^4.3.4"
    },
    "peerDependencies": {
        "@aws-sdk/client-sqs": "^3.391.0"
    },
    "publishConfig": {
        "access": "restricted",
        "registry": "https://npm.pkg.github.com"
    }
}
